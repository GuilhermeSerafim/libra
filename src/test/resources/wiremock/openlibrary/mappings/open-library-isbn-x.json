{
  "request": {
    "method": "GET",
    "urlPath": "/api/books",
    "queryParameters": {
      "bibkeys": {
        "equalTo": "ISBN:012345678X"
      },
      "format": {
        "equalTo": "json"
      },
      "jscmd": {
        "equalTo": "data"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "open-library-isbn-x-response.json"
  }
}
